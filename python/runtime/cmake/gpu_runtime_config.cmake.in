@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Find optional dependencies
find_dependency(Vulkan)
find_dependency(OpenCL)

# Note: CUDA and HIP dependencies are handled differently
# Users should link against CUDA::cudart / roc::hip_runtime explicitly if needed

include("${CMAKE_CURRENT_LIST_DIR}/gpu_runtime_targets.cmake")

check_required_components(gpu_runtime)
