#version 450
#extension GL_ARB_gpu_shader_fp64 : enable
double gpu_cbrt_pos_f64(double x) {
  double ax = (x > 0.0 ? x : 0.0);
  if (ax == 0.0) { return 0.0; }
  double y = double(pow(float(ax), 0.3333333432674408));
  if (y == 0.0) { y = 1.0e-100; }
  y = ((2.0 * y) + (ax / (y * y))) / 3.0;
  y = ((2.0 * y) + (ax / (y * y))) / 3.0;
  y = ((2.0 * y) + (ax / (y * y))) / 3.0;
  y = ((2.0 * y) + (ax / (y * y))) / 3.0;
  y = ((2.0 * y) + (ax / (y * y))) / 3.0;
  return y;
}

double gpu_pow_pos_f64_two_thirds(double x) {
  double r = gpu_cbrt_pos_f64(x);
  return r * r;
}

layout(local_size_x = 1, local_size_y = 1, local_size_z = 1) in;

layout(std430, binding = 0) readonly buffer buf_n {
  uint n[];
};
layout(std430, binding = 1) readonly buffer buf_M2 {
  double M2[];
};
layout(std430, binding = 2) readonly buffer buf_M4 {
  double M4[];
};
layout(std430, binding = 3) writeonly buffer buf_excessKurtosis {
  double excessKurtosis[];
};

// kernel: navatala_dataframe_extract_excess_kurtosis_f64
void main() {
  int gid0 = int(gl_GlobalInvocationID.x);
  if (int(gl_GlobalInvocationID.x) == 0) {
    uint nVal = n[0];
    double m2Val = M2[0];
    double m4Val = M4[0];
    double nf = double(nVal);
    double m2Sq = (m2Val * m2Val);
    double denomSafe = (((m2Val == packDouble2x32(uvec2(0x00000000u, 0x00000000u)))) ? (packDouble2x32(uvec2(0x00000000u, 0x3ff00000u))) : (m2Sq));
    double numerator = (nf * m4Val);
    double kurtRaw = (numerator / denomSafe);
    double excessRaw = (kurtRaw - packDouble2x32(uvec2(0x00000000u, 0x40080000u)));
    double excessResult = (((m2Val == packDouble2x32(uvec2(0x00000000u, 0x00000000u)))) ? (packDouble2x32(uvec2(0x00000000u, 0x00000000u))) : (excessRaw));
    excessKurtosis[0] = excessResult;
  }
}
