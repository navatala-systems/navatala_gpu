#version 450
layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(std430, binding = 0) readonly buffer buf_y_true {
  float y_true[];
};
layout(std430, binding = 1) readonly buffer buf_y_pred {
  float y_pred[];
};
layout(std430, binding = 2) readonly buffer buf_n {
  uint n[];
};
layout(std430, binding = 3) writeonly buffer buf_result {
  float result[];
};

shared float sdata[256];

// kernel: navatala_dataframe_mse_f32
void main() {
  int gid0 = int(gl_GlobalInvocationID.x);
  uint gid = uint(int(gl_GlobalInvocationID.x));
  uint lid = uint(int(gl_LocalInvocationID.x));
  uint countVal = n[0];
  bool inBounds = (gid < countVal);
  float trueVal = y_true[gid];
  float predVal = y_pred[gid];
  float diff = (trueVal - predVal);
  float sqErr = (diff * diff);
  if (inBounds) {
    sdata[lid] = sqErr;
  } else {
    sdata[lid] = uintBitsToFloat(0x00000000u);
  }
  barrier();
  uint mseF32_reductionStride = 128u;
  for (int reductionStep = 0; reductionStep < int(8); ++reductionStep) {
    uint mseF32_stride = mseF32_reductionStride;
    if ((lid < mseF32_stride)) {
      uint mseF32_partnerIdx = (lid + mseF32_stride);
      float other = sdata[mseF32_partnerIdx];
      float mine = sdata[lid];
      float sum = (mine + other);
      sdata[lid] = sum;
    }
    uint mseF32_strideToHalve = mseF32_reductionStride;
    uint mseF32_nextStride = (mseF32_strideToHalve >> 1u);
    mseF32_reductionStride = mseF32_nextStride;
    barrier();
  }
  uint zeroU32 = uint(0);
  if ((lid == zeroU32)) {
    float totalSum = sdata[0];
    float countFloat = float(countVal);
    float mseVal = (totalSum / countFloat);
    result[0] = mseVal;
  }
}
