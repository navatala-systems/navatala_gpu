#version 450
layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(std430, binding = 0) readonly buffer buf_y_true {
  float y_true[];
};
layout(std430, binding = 1) readonly buffer buf_y_pred {
  float y_pred[];
};
layout(std430, binding = 2) readonly buffer buf_n {
  uint n[];
};
layout(std430, binding = 3) writeonly buffer buf_result {
  float result[];
};

shared float sdata[256];

// kernel: navatala_dataframe_mape_f32
void main() {
  int gid0 = int(gl_GlobalInvocationID.x);
  uint gid = uint(int(gl_GlobalInvocationID.x));
  uint lid = uint(int(gl_LocalInvocationID.x));
  uint countVal = n[0];
  bool inBounds = (gid < countVal);
  float trueVal = y_true[gid];
  float predVal = y_pred[gid];
  float diff = (trueVal - predVal);
  float absErr = abs(diff);
  float absTrueVal = abs(trueVal);
  float pctErr = (absErr / absTrueVal);
  if (inBounds) {
    sdata[lid] = pctErr;
  } else {
    sdata[lid] = uintBitsToFloat(0x00000000u);
  }
  barrier();
  uint mapeF32_reductionStride = 128u;
  for (int reductionStep = 0; reductionStep < int(8); ++reductionStep) {
    uint mapeF32_stride = mapeF32_reductionStride;
    if ((lid < mapeF32_stride)) {
      uint mapeF32_partnerIdx = (lid + mapeF32_stride);
      float other = sdata[mapeF32_partnerIdx];
      float mine = sdata[lid];
      float sum = (mine + other);
      sdata[lid] = sum;
    }
    uint mapeF32_strideToHalve = mapeF32_reductionStride;
    uint mapeF32_nextStride = (mapeF32_strideToHalve >> 1u);
    mapeF32_reductionStride = mapeF32_nextStride;
    barrier();
  }
  uint zeroU32 = uint(0);
  if ((lid == zeroU32)) {
    float totalSum = sdata[0];
    float countFloat = float(countVal);
    float avgPctErr = (totalSum / countFloat);
    float mapeVal = (uintBitsToFloat(0x42c80000u) * avgPctErr);
    result[0] = mapeVal;
  }
}
