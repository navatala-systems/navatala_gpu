#version 450
layout(local_size_x = 1, local_size_y = 1, local_size_z = 1) in;

layout(std430, binding = 0) readonly buffer buf_sortedData {
  float sortedData[];
};
layout(std430, binding = 1) readonly buffer buf_n {
  uint n[];
};
layout(std430, binding = 2) readonly buffer buf_median {
  float median[];
};
layout(std430, binding = 3) writeonly buffer buf_mad {
  float mad[];
};

// kernel: navatala_dataframe_mad_f32
void main() {
  int gid0 = int(gl_GlobalInvocationID.x);
  uint gid = uint(int(gl_GlobalInvocationID.x));
  if ((gid == 0u)) {
    uint len = n[0];
    float med = median[0];
    uint q1Idx = (len / 4u);
    uint q3Idx = (len - q1Idx);
    float q1Val = sortedData[q1Idx];
    float q3Val = sortedData[q3Idx];
    float dev1 = abs((q1Val - med));
    float dev3 = abs((q3Val - med));
    float madVal = ((dev1 + dev3) / uintBitsToFloat(0x40000000u));
    mad[0] = madVal;
  }
}
