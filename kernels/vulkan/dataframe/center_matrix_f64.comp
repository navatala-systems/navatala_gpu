#version 450
layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(std430, binding = 0) readonly buffer buf__input {
  double _input[];
};
layout(std430, binding = 1) readonly buffer buf_nSamples {
  uint nSamples[];
};
layout(std430, binding = 2) readonly buffer buf_nFeatures {
  uint nFeatures[];
};
layout(std430, binding = 3) readonly buffer buf_means {
  double means[];
};
layout(std430, binding = 4) writeonly buffer buf__output {
  double _output[];
};

// kernel: navatala_dataframe_center_matrix_f64
void main() {
  int gid0 = int(gl_GlobalInvocationID.x);
  uint gid = uint(int(gl_GlobalInvocationID.x));
  uint n = nSamples[0];
  uint d = nFeatures[0];
  uint totalElems = (n * d);
  bool inBounds = (gid < totalElems);
  if (inBounds) {
    uint colIdx = (gid % d);
    double x = _input[gid];
    double colMean = means[colIdx];
    double centered = (x - colMean);
    _output[gid] = centered;
  }
}
