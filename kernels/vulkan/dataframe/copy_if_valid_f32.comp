#version 450
layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(std430, binding = 0) readonly buffer buf_src {
  float src[];
};
layout(std430, binding = 1) readonly buffer buf_srcValid {
  uint srcValid[];
};
layout(std430, binding = 2) readonly buffer buf_dstValid {
  uint dstValid[];
};
layout(std430, binding = 3) readonly buffer buf_count {
  uint count[];
};
layout(std430, binding = 4) buffer buf_dst {
  float dst[];
};
layout(std430, binding = 5) buffer buf_outValid {
  uint outValid[];
};

// kernel: navatala_dataframe_copy_if_valid_f32
void main() {
  int gid0 = int(gl_GlobalInvocationID.x);
  uint gid = uint(int(gl_GlobalInvocationID.x));
  uint n = count[0u];
  bool inBounds = (gid < n);
  if (inBounds) {
    uint wordIdx = (gid / 32u);
    uint bitIdx = (gid % 32u);
    uint srcValidWord = srcValid[wordIdx];
    uint srcValidBit = ((srcValidWord >> bitIdx) & 1u);
    bool srcIsValid = (srcValidBit == 1u);
    uint dstValidWord = dstValid[wordIdx];
    uint dstValidBit = ((dstValidWord >> bitIdx) & 1u);
    bool dstIsValid = (dstValidBit == 1u);
    bool bothValid = (srcIsValid && dstIsValid);
    if (bothValid) {
      float val = src[gid];
      dst[gid] = val;
      uint outBit = (1u << bitIdx);
      atomicOr(outValid[wordIdx], outBit);
    }
  }
}
