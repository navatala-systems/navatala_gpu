#version 450
layout(local_size_x = 1, local_size_y = 1, local_size_z = 1) in;

layout(std430, binding = 0) readonly buffer buf_n {
  uint n[];
};
layout(std430, binding = 1) readonly buffer buf_M2 {
  double M2[];
};
layout(std430, binding = 2) readonly buffer buf_M3 {
  double M3[];
};
layout(std430, binding = 3) writeonly buffer buf_skewness {
  double skewness[];
};

// kernel: navatala_dataframe_extract_skewness_f64
void main() {
  int gid0 = int(gl_GlobalInvocationID.x);
  if (int(gl_GlobalInvocationID.x) == 0) {
    uint nVal = n[0];
    double m2Val = M2[0];
    double m3Val = M3[0];
    double nf = double(nVal);
    double sqrtN = sqrt(nf);
    double sqrtM2 = sqrt(m2Val);
    double m2Pow15 = (m2Val * sqrtM2);
    double denomSafe = (((m2Val == packDouble2x32(uvec2(0x00000000u, 0x00000000u)))) ? (packDouble2x32(uvec2(0x00000000u, 0x3ff00000u))) : (m2Pow15));
    double numerator = (sqrtN * m3Val);
    double skewRaw = (numerator / denomSafe);
    double skewResult = (((m2Val == packDouble2x32(uvec2(0x00000000u, 0x00000000u)))) ? (packDouble2x32(uvec2(0x00000000u, 0x00000000u))) : (skewRaw));
    skewness[0] = skewResult;
  }
}
