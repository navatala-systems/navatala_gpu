#version 450
#extension GL_EXT_shader_explicit_arithmetic_types_float16 : enable
#extension GL_EXT_shader_16bit_storage : enable
layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(std430, binding = 0) readonly buffer buf__input {
  float16_t _input[];
};
layout(std430, binding = 1) readonly buffer buf_batchSize {
  uint batchSize[];
};
layout(std430, binding = 2) readonly buffer buf_seqLen {
  uint seqLen[];
};
layout(std430, binding = 3) writeonly buffer buf__output {
  float16_t _output[];
};

shared float maxBuf[256];
shared float sumBuf[256];

// kernel: navatala_transformer_softmax_forward_f16
void main() {
  int gid0 = int(gl_GlobalInvocationID.x);
  uint lid = uint(int(gl_LocalInvocationID.x));
  uint batchIdx = uint(int(gl_WorkGroupID.x));
  uint bs = batchSize[0u];
  uint sl = seqLen[0u];
  bool batchValid = (batchIdx < bs);
  bool seqValid = (lid < sl);
  uint globalIdx = ((batchIdx * sl) + lid);
  float16_t xF16 = (((batchValid && seqValid)) ? (_input[globalIdx]) : (float16_t(0.000000)));
  float x = ((seqValid) ? (float(xF16)) : (uintBitsToFloat(0xf149f2cau)));
  maxBuf[lid] = x;
  barrier();
  bool shouldReduce_max_maxBuf_128 = (lid < 128u);
  if (shouldReduce_max_maxBuf_128) {
    uint neighborIdx_max_maxBuf_128 = (lid + 128u);
    float myVal_max_maxBuf_128 = maxBuf[lid];
    float neighborVal_max_maxBuf_128 = maxBuf[neighborIdx_max_maxBuf_128];
    bool isGreater_max_maxBuf_128 = (neighborVal_max_maxBuf_128 > myVal_max_maxBuf_128);
    float maxVal_max_maxBuf_128 = ((isGreater_max_maxBuf_128) ? (neighborVal_max_maxBuf_128) : (myVal_max_maxBuf_128));
    maxBuf[lid] = maxVal_max_maxBuf_128;
  }
  barrier();
  bool shouldReduce_max_maxBuf_64 = (lid < 64u);
  if (shouldReduce_max_maxBuf_64) {
