#version 450
#extension GL_EXT_shader_explicit_arithmetic_types_float16 : enable
#extension GL_EXT_shader_16bit_storage : enable
layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(std430, binding = 0) readonly buffer buf_expertIndices {
  int expertIndices[];
};
layout(std430, binding = 1) readonly buffer buf_numTokens {
  uint numTokens[];
};
layout(std430, binding = 2) readonly buffer buf_numExperts {
  uint numExperts[];
};
layout(std430, binding = 3) readonly buffer buf_topK {
  uint topK[];
};
layout(std430, binding = 4) readonly buffer buf_capacity {
  uint capacity[];
};
layout(std430, binding = 5) writeonly buffer buf_mask {
  float16_t mask[];
};

shared uint expertCounts[256];

// kernel: navatala_transformer_expert_capacity_mask_f16
void main() {
  int gid0 = int(gl_GlobalInvocationID.x);
  uint gid = uint(int(gl_GlobalInvocationID.x));
  uint nt = numTokens[0u];
  uint ne = numExperts[0u];
  uint k = topK[0u];
  uint cap = capacity[0u];
  uint lid = uint(int(gl_LocalInvocationID.x));
  if ((lid < ne)) {
    expertCounts[lid] = 0u;
  }
  barrier();
  uint totalElements = (nt * k);
  bool valid = (gid < totalElements);
  if (valid) {
    int expertIdx = expertIndices[gid];
    uint expertIdxU32 = uint(expertIdx);
    bool expertIdxValid = (expertIdxU32 < ne);
    if (expertIdxValid) {
      uint prevCount = atomicAdd(expertCounts[expertIdxU32], 1u);
      bool withinCapacity = (prevCount < cap);
      float16_t maskVal = ((withinCapacity) ? (float16_t(1.000000)) : (float16_t(0.000000)));
      mask[gid] = maskVal;
    } else {
      mask[gid] = float16_t(0.000000);
    }
  }
}
