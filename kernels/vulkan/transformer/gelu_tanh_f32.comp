#version 450
layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(std430, binding = 0) readonly buffer buf__input {
  float _input[];
};
layout(std430, binding = 1) readonly buffer buf_count {
  uint count[];
};
layout(std430, binding = 2) writeonly buffer buf__output {
  float _output[];
};

// kernel: navatala_transformer_gelu_tanh_f32
void main() {
  int gid0 = int(gl_GlobalInvocationID.x);
  uint gid = uint(int(gl_GlobalInvocationID.x));
  uint n = count[0u];
  bool inBounds = (gid < n);
  if (inBounds) {
    float x = _input[gid];
    float x2 = (x * x);
    float x3 = (x2 * x);
    float cubeTerm = (uintBitsToFloat(0x3d372713u) * x3);
    float inner = (x + cubeTerm);
    float tanhArg = (uintBitsToFloat(0x3f4c422au) * inner);
    float tanhVal = tanh(tanhArg);
    float onePlusTanh = (uintBitsToFloat(0x3f800000u) + tanhVal);
    float halfX = (uintBitsToFloat(0x3f000000u) * x);
    float result = (halfX * onePlusTanh);
    _output[gid] = result;
  }
}
