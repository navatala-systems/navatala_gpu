#version 450
layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(std430, binding = 0) readonly buffer buf_a {
  double a[];
};
layout(std430, binding = 1) readonly buffer buf_b {
  double b[];
};
layout(std430, binding = 2) readonly buffer buf_vecLen {
  uint vecLen[];
};
layout(std430, binding = 3) readonly buffer buf_batchSize {
  uint batchSize[];
};
layout(std430, binding = 4) writeonly buffer buf_result {
  double result[];
};

// kernel: navatala_linalg_batched_dot_f64
void main() {
  int gid0 = int(gl_GlobalInvocationID.x);
  uint gid = uint(int(gl_GlobalInvocationID.x));
  uint len = vecLen[0u];
  uint numBatches = batchSize[0u];
  uint k = gid;
  bool inBounds = (k < numBatches);
  if (inBounds) {
    uint baseOffset = (k * len);
    double sumAccum = packDouble2x32(uvec2(0x00000000u, 0x00000000u));
    for (int i = 0; i < int(len); ++i) {
      uint iU32 = uint(i);
      uint idx = (baseOffset + iU32);
      double aVal = a[idx];
      double bVal = b[idx];
      double prod = (aVal * bVal);
      double currentSum = sumAccum;
      double nextSum = (currentSum + prod);
      sumAccum = nextSum;
    }
    double finalSum = sumAccum;
    result[k] = finalSum;
  }
}
