#version 450
layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(std430, binding = 0) readonly buffer buf_X {
  float X[];
};
layout(std430, binding = 1) readonly buffer buf_Y {
  float Y[];
};
layout(std430, binding = 2) readonly buffer buf_n {
  uint n[];
};
layout(std430, binding = 3) readonly buffer buf_m {
  uint m[];
};
layout(std430, binding = 4) readonly buffer buf_d {
  uint d[];
};
layout(std430, binding = 5) writeonly buffer buf_D {
  float D[];
};

// kernel: navatala_ml_pairwise_squared_euclidean_f32
void main() {
  int gid0 = int(gl_GlobalInvocationID.x);
  uint gid = uint(int(gl_GlobalInvocationID.x));
  uint nVal = n[0];
  uint mVal = m[0];
  uint dVal = d[0];
  uint totalElems = (nVal * mVal);
  bool inBounds = (gid < totalElems);
  if (inBounds) {
    uint i = (gid / mVal);
    uint j = (gid % mVal);
    uint xBase = (i * dVal);
    uint yBase = (j * dVal);
    float sumSq = uintBitsToFloat(0x00000000u);
    for (int k = 0; k < int(dVal); ++k) {
      uint kU32 = uint(k);
      uint xIdx = (xBase + kU32);
      uint yIdx = (yBase + kU32);
      float xVal = X[xIdx];
      float yVal = Y[yIdx];
      float diff = (xVal - yVal);
      float diffSq = (diff * diff);
      float currentSum = sumSq;
      float newSum = (currentSum + diffSq);
      sumSq = newSum;
    }
    float finalSum = sumSq;
    D[gid] = finalSum;
  }
}
