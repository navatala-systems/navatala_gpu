#version 450
#extension GL_ARB_gpu_shader_fp64 : enable
double gpu_cbrt_pos_f64(double x) {
  double ax = (x > 0.0 ? x : 0.0);
  if (ax == 0.0) { return 0.0; }
  double y = double(pow(float(ax), 0.3333333432674408));
  if (y == 0.0) { y = 1.0e-100; }
  y = ((2.0 * y) + (ax / (y * y))) / 3.0;
  y = ((2.0 * y) + (ax / (y * y))) / 3.0;
  y = ((2.0 * y) + (ax / (y * y))) / 3.0;
  y = ((2.0 * y) + (ax / (y * y))) / 3.0;
  y = ((2.0 * y) + (ax / (y * y))) / 3.0;
  return y;
}

double gpu_pow_pos_f64_two_thirds(double x) {
  double r = gpu_cbrt_pos_f64(x);
  return r * r;
}

layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(std430, binding = 0) readonly buffer buf_neighborIndices {
  uint neighborIndices[];
};
layout(std430, binding = 1) readonly buffer buf_neighborDistances {
  double neighborDistances[];
};
layout(std430, binding = 2) readonly buffer buf_targetValues {
  double targetValues[];
};
layout(std430, binding = 3) readonly buffer buf_q {
  uint q[];
};
layout(std430, binding = 4) readonly buffer buf_k {
  uint k[];
};
layout(std430, binding = 5) writeonly buffer buf_predictions {
  double predictions[];
};

// kernel: navatala_ml_knn_regress_weighted_f64
void main() {
  int gid0 = int(gl_GlobalInvocationID.x);
  uint gid = uint(int(gl_GlobalInvocationID.x));
  uint qVal = q[0];
  uint kVal = k[0];
  bool inBounds = (gid < qVal);
  if (inBounds) {
    uint baseIdx = (gid * kVal);
    double weightedSumAccum = packDouble2x32(uvec2(0x00000000u, 0x00000000u));
    double weightSumAccum = packDouble2x32(uvec2(0x00000000u, 0x00000000u));
    double epsilon = packDouble2x32(uvec2(0x9ee75616u, 0x3cd203afu));
    for (int j = 0; j < int(kVal); ++j) {
      uint jU32 = uint(j);
      uint neighborOffset = (baseIdx + jU32);
      uint neighborIdx = neighborIndices[neighborOffset];
      double dist = neighborDistances[neighborOffset];
      double targetVal = targetValues[neighborIdx];
      double safeDist = (((dist < epsilon)) ? (epsilon) : (dist));
      double weight = (packDouble2x32(uvec2(0x00000000u, 0x3ff00000u)) / safeDist);
      double currentWeightedSum = weightedSumAccum;
      double newWeightedSum = (currentWeightedSum + (targetVal * weight));
      weightedSumAccum = newWeightedSum;
      double currentWeightSum = weightSumAccum;
      double newWeightSum = (currentWeightSum + weight);
      weightSumAccum = newWeightSum;
    }
    double finalWeightedSum = weightedSumAccum;
    double finalWeightSum = weightSumAccum;
    double safeDenom = (((finalWeightSum == packDouble2x32(uvec2(0x00000000u, 0x00000000u)))) ? (packDouble2x32(uvec2(0x00000000u, 0x3ff00000u))) : (finalWeightSum));
    double prediction = (finalWeightedSum / safeDenom);
    predictions[gid] = prediction;
  }
}
