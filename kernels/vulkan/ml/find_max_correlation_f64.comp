#version 450
#extension GL_ARB_gpu_shader_fp64 : enable
double gpu_cbrt_pos_f64(double x) {
  double ax = (x > 0.0 ? x : 0.0);
  if (ax == 0.0) { return 0.0; }
  double y = double(pow(float(ax), 0.3333333432674408));
  if (y == 0.0) { y = 1.0e-100; }
  y = ((2.0 * y) + (ax / (y * y))) / 3.0;
  y = ((2.0 * y) + (ax / (y * y))) / 3.0;
  y = ((2.0 * y) + (ax / (y * y))) / 3.0;
  y = ((2.0 * y) + (ax / (y * y))) / 3.0;
  y = ((2.0 * y) + (ax / (y * y))) / 3.0;
  return y;
}

double gpu_pow_pos_f64_two_thirds(double x) {
  double r = gpu_cbrt_pos_f64(x);
  return r * r;
}

layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(std430, binding = 0) readonly buffer buf_correlations {
  double correlations[];
};
layout(std430, binding = 1) readonly buffer buf_activeMask {
  uint activeMask[];
};
layout(std430, binding = 2) readonly buffer buf_nCols {
  uint nCols[];
};
layout(std430, binding = 3) writeonly buffer buf_maxIndex {
  uint maxIndex[];
};
layout(std430, binding = 4) writeonly buffer buf_maxValue {
  double maxValue[];
};

shared double svals[256];
shared uint sidxs[256];

// kernel: navatala_ml_find_max_correlation_f64
void main() {
  int gid0 = int(gl_GlobalInvocationID.x);
  uint gid = uint(int(gl_GlobalInvocationID.x));
  uint lid = uint(int(gl_LocalInvocationID.x));
  double otherVal = packDouble2x32(uvec2(0x00000000u, 0x00000000u));
  uint otherIdx = 0u;
  double myVal = packDouble2x32(uvec2(0x00000000u, 0x00000000u));
  uint myIdx = 0u;
  bool takeOther = false;
  uint d = nCols[0];
  bool inBounds = (gid < d);
  if (inBounds) {
    uint mask = activeMask[gid];
    bool isActive = (mask == 1u);
    double corr = correlations[gid];
    double absCorr = abs(corr);
    double val = ((isActive) ? (absCorr) : (packDouble2x32(uvec2(0xffffffffu, 0xffefffffu))));
    svals[lid] = val;
    sidxs[lid] = gid;
  } else {
    svals[lid] = packDouble2x32(uvec2(0xffffffffu, 0xffefffffu));
    sidxs[lid] = 0u;
  }
  barrier();
  uint maxCorrF64RedStride = 128u;
  for (int maxCorrF64RedStep = 0; maxCorrF64RedStep < int(8); ++maxCorrF64RedStep) {
    uint maxCorrF64Stride = maxCorrF64RedStride;
    if (lid < maxCorrF64Stride) {
      otherVal = svals[(lid + maxCorrF64Stride)];
      otherIdx = sidxs[(lid + maxCorrF64Stride)];
      myVal = svals[lid];
      myIdx = sidxs[lid];
      takeOther = (otherVal > myVal);
      if (takeOther) {
        svals[lid] = otherVal;
        sidxs[lid] = otherIdx;
      }
    }
    uint maxCorrF64StrideToHalve = maxCorrF64RedStride;
    uint maxCorrF64NextStride = (maxCorrF64StrideToHalve >> 1u);
    maxCorrF64RedStride = maxCorrF64NextStride;
    barrier();
  }
  if (lid == 0u) {
    maxValue[0] = svals[0];
    maxIndex[0] = sidxs[0];
  }
}
