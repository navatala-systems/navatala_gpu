};
layout(std430, binding = 5) readonly buffer buf_rAUf {
  float rAUf[];
};
layout(std430, binding = 6) readonly buffer buf_phig {
  float phig[];
};
layout(std430, binding = 7) readonly buffer buf_owner {
  int owner[];
};
layout(std430, binding = 8) readonly buffer buf_neighbour {
  int neighbour[];
};
layout(std430, binding = 9) readonly buffer buf_sfX {
  float sfX[];
};
layout(std430, binding = 10) readonly buffer buf_sfY {
  float sfY[];
};
layout(std430, binding = 11) readonly buffer buf_sfZ {
