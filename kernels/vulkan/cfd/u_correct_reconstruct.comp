#version 450
layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(std430, binding = 0) readonly buffer buf_pCell {
  float pCell[];
};
layout(std430, binding = 1) readonly buffer buf_rAU {
  float rAU[];
};
