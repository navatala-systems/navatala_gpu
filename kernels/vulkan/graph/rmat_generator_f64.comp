#version 450
layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(std430, binding = 0) readonly buffer buf_random {
  double random[];
};
layout(std430, binding = 1) readonly buffer buf_randomWeights {
  double randomWeights[];
};
layout(std430, binding = 2) readonly buffer buf_a {
  double a[];
};
layout(std430, binding = 3) readonly buffer buf_b {
  double b[];
};
layout(std430, binding = 4) readonly buffer buf_c {
  double c[];
};
layout(std430, binding = 5) readonly buffer buf_d {
  double d[];
};
layout(std430, binding = 6) readonly buffer buf_n {
  uint n[];
};
layout(std430, binding = 7) readonly buffer buf_scale {
  uint scale[];
};
layout(std430, binding = 8) readonly buffer buf_numEdges {
  uint numEdges[];
};
layout(std430, binding = 9) writeonly buffer buf_srcNodes {
  uint srcNodes[];
};
layout(std430, binding = 10) writeonly buffer buf_dstNodes {
  uint dstNodes[];
};
layout(std430, binding = 11) writeonly buffer buf_weights {
  double weights[];
};
layout(std430, binding = 12) buffer buf_edgeCount {
  uint edgeCount[];
};

// kernel: navatala_graph_rmat_generator_f64
void main() {
  int gid0 = int(gl_GlobalInvocationID.x);
  uint gid = uint(int(gl_GlobalInvocationID.x));
  uint numE = numEdges[0u];
  bool inBounds = (gid < numE);
  if (inBounds) {
    double probA = a[0u];
    double probB = b[0u];
    double probC = c[0u];
    uint scaleVal = scale[0u];
    double ab = (probA + probB);
    double abc = (ab + probC);
    uint srcAccum = 0u;
    uint dstAccum = 0u;
    for (int level = 0; level < int(scaleVal); ++level) {
      uint levelU32 = uint(level);
      uint randIdx = ((gid * scaleVal) + levelU32);
      double r = random[randIdx];
      uint bitPos = ((scaleVal - levelU32) - 1u);
      uint bitMask = (1u << bitPos);
      bool inQ01 = (r >= probA);
      bool inQ10 = (r >= ab);
      bool inQ11 = (r >= abc);
      uint srcBit = ((inQ10) ? (bitMask) : (0u));
      uint currentSrc = srcAccum;
      uint newSrc = (currentSrc | srcBit);
      srcAccum = newSrc;
      bool dstBitCond = ((inQ01 && (!inQ10)) || inQ11);
      uint dstBit = ((dstBitCond) ? (bitMask) : (0u));
      uint currentDst = dstAccum;
      uint newDst = (currentDst | dstBit);
      dstAccum = newDst;
    }
    uint src = srcAccum;
    uint dst = dstAccum;
    double w = randomWeights[gid];
    uint slot = atomicAdd(edgeCount[0u], 1u);
    srcNodes[slot] = src;
    dstNodes[slot] = dst;
    weights[slot] = w;
  }
}
