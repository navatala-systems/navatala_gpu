#version 450
layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(std430, binding = 0) readonly buffer buf_muCell {
  float muCell[];
};
layout(std430, binding = 1) readonly buffer buf_muBc {
  float muBc[];
};
layout(std430, binding = 2) readonly buffer buf_gXX {
  float gXX[];
};
layout(std430, binding = 3) readonly buffer buf_gXY {
  float gXY[];
};
layout(std430, binding = 4) readonly buffer buf_gXZ {
  float gXZ[];
};
layout(std430, binding = 5) readonly buffer buf_gYX {
  float gYX[];
};
layout(std430, binding = 6) readonly buffer buf_gYY {
  float gYY[];
};
layout(std430, binding = 7) readonly buffer buf_gYZ {
  float gYZ[];
};
layout(std430, binding = 8) readonly buffer buf_gZX {
  float gZX[];
};
layout(std430, binding = 9) readonly buffer buf_gZY {
  float gZY[];
};
layout(std430, binding = 10) readonly buffer buf_gZZ {
  float gZZ[];
};
layout(std430, binding = 11) readonly buffer buf_owner {
  int owner[];
};
layout(std430, binding = 12) readonly buffer buf_neighbour {
  int neighbour[];
};
layout(std430, binding = 13) readonly buffer buf_weights {
  float weights[];
};
layout(std430, binding = 14) readonly buffer buf_sfX {
  float sfX[];
};
layout(std430, binding = 15) readonly buffer buf_sfY {
  float sfY[];
};
layout(std430, binding = 16) readonly buffer buf_sfZ {
  float sfZ[];
};
layout(std430, binding = 17) readonly buffer buf_offsets {
  int offsets[];
};
layout(std430, binding = 18) readonly buffer buf_faceIdx {
  int faceIdx[];
};
layout(std430, binding = 19) readonly buffer buf_signF {
  float signF[];
};
layout(std430, binding = 20) readonly buffer buf_vol {
  float vol[];
};
layout(std430, binding = 21) readonly buffer buf_params {
  int params[];
};
layout(std430, binding = 22) writeonly buffer buf_outX {
  float outX[];
};
layout(std430, binding = 23) writeonly buffer buf_outY {
  float outY[];
};
layout(std430, binding = 24) writeonly buffer buf_outZ {
  float outZ[];
};

// kernel: navatala_cfd_primitives_div_mu_dev2_t_grad_u_from_grad_v2
void main() {
  int gid0 = int(gl_GlobalInvocationID.x);
  if (int(int(gl_GlobalInvocationID.x)) >= params[0]) {
    return;
  } else {
    float sumX = uintBitsToFloat(0x00000000u);
    float sumY = uintBitsToFloat(0x00000000u);
    float sumZ = uintBitsToFloat(0x00000000u);
    int beg = offsets[int(int(gl_GlobalInvocationID.x))];
    int c1 = (int(int(gl_GlobalInvocationID.x)) + 1);
    int end = offsets[c1];
    int len = (end - beg);
    for (int t = 0; t < int(len); ++t) {
      int k = (beg + t);
      int f = faceIdx[k];
      if (f < params[1]) {
        float s = signF[k];
        int o = owner[f];
        float muO = muCell[o];
        float goXX = gXX[o];
        float goXY = gXY[o];
        float goXZ = gXZ[o];
        float goYX = gYX[o];
        float goYY = gYY[o];
        float goYZ = gYZ[o];
        float goZX = gZX[o];
        float goZY = gZY[o];
        float goZZ = gZZ[o];
        float trO = (goXX + (goYY + goZZ));
        float twoThirdO = (uintBitsToFloat(0x3f2aaaabu) * trO);
        float tOxx = (goXX - twoThirdO);
        float tOxy = goYX;
        float tOxz = goZX;
        float tOyx = goXY;
        float tOyy = (goYY - twoThirdO);
        float tOyz = goZY;
        float tOzx = goXZ;
        float tOzy = goYZ;
        float tOzz = (goZZ - twoThirdO);
        float tauOxx = (muO * tOxx);
        float tauOxy = (muO * tOxy);
        float tauOxz = (muO * tOxz);
        float tauOyx = (muO * tOyx);
        float tauOyy = (muO * tOyy);
        float tauOyz = (muO * tOyz);
        float tauOzx = (muO * tOzx);
        float tauOzy = (muO * tOzy);
        float tauOzz = (muO * tOzz);
        float tauFxx = tauOxx;
        float tauFxy = tauOxy;
        float tauFxz = tauOxz;
        float tauFyx = tauOyx;
        float tauFyy = tauOyy;
        float tauFyz = tauOyz;
        float tauFzx = tauOzx;
        float tauFzy = tauOzy;
        float tauFzz = tauOzz;
        int n = neighbour[f];
        if (n >= 0) {
          float muN = muCell[n];
          float gnXX = gXX[n];
          float gnXY = gXY[n];
          float gnXZ = gXZ[n];
          float gnYX = gYX[n];
          float gnYY = gYY[n];
          float gnYZ = gYZ[n];
          float gnZX = gZX[n];
          float gnZY = gZY[n];
          float gnZZ = gZZ[n];
          float trN = (gnXX + (gnYY + gnZZ));
          float twoThirdN = (uintBitsToFloat(0x3f2aaaabu) * trN);
          float tNxx = (gnXX - twoThirdN);
          float tNxy = gnYX;
          float tNxz = gnZX;
          float tNyx = gnXY;
          float tNyy = (gnYY - twoThirdN);
          float tNyz = gnZY;
          float tNzx = gnXZ;
          float tNzy = gnYZ;
          float tNzz = (gnZZ - twoThirdN);
          float tauNxx = (muN * tNxx);
          float tauNxy = (muN * tNxy);
          float tauNxz = (muN * tNxz);
          float tauNyx = (muN * tNyx);
          float tauNyy = (muN * tNyy);
          float tauNyz = (muN * tNyz);
          float tauNzx = (muN * tNzx);
          float tauNzy = (muN * tNzy);
          float tauNzz = (muN * tNzz);
          float ww = weights[f];
          float iw = (uintBitsToFloat(0x3f800000u) - ww);
          tauFxx = ((ww * tauOxx) + (iw * tauNxx));
          tauFxy = ((ww * tauOxy) + (iw * tauNxy));
          tauFxz = ((ww * tauOxz) + (iw * tauNxz));
          tauFyx = ((ww * tauOyx) + (iw * tauNyx));
          tauFyy = ((ww * tauOyy) + (iw * tauNyy));
          tauFyz = ((ww * tauOyz) + (iw * tauNyz));
          tauFzx = ((ww * tauOzx) + (iw * tauNzx));
          tauFzy = ((ww * tauOzy) + (iw * tauNzy));
          tauFzz = ((ww * tauOzz) + (iw * tauNzz));
        }
        float sx = sfX[f];
        float sy = sfY[f];
        float sz = sfZ[f];
        float fluxX = ((sx * tauFxx) + ((sy * tauFyx) + (sz * tauFzx)));
        float fluxY = ((sx * tauFxy) + ((sy * tauFyy) + (sz * tauFzy)));
        float fluxZ = ((sx * tauFxz) + ((sy * tauFyz) + (sz * tauFzz)));
        float wX = (s * fluxX);
        float wY = (s * fluxY);
        float wZ = (s * fluxZ);
        sumX = (sumX + wX);
        sumY = (sumY + wY);
        sumZ = (sumZ + wZ);
      }
    }
    float v = vol[int(int(gl_GlobalInvocationID.x))];
    float invV = uintBitsToFloat(0x00000000u);
    if (v != uintBitsToFloat(0x00000000u)) {
      invV = (uintBitsToFloat(0x3f800000u) / v);
    }
    outX[int(int(gl_GlobalInvocationID.x))] = (sumX * invV);
    outY[int(int(gl_GlobalInvocationID.x))] = (sumY * invV);
    outZ[int(int(gl_GlobalInvocationID.x))] = (sumZ * invV);
  }
}
