#version 450
layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(std430, binding = 0) readonly buffer buf_X {
  float X[];
};
layout(std430, binding = 1) readonly buffer buf_coeffs {
  float coeffs[];
};
layout(std430, binding = 2) readonly buffer buf_n {
  uint n[];
};
layout(std430, binding = 3) readonly buffer buf_j {
  uint j[];
};
layout(std430, binding = 4) readonly buffer buf_k {
  uint k[];
};
layout(std430, binding = 5) buffer buf_Xj {
  float Xj[];
};

// kernel: navatala_sparse_block_gram_schmidt_f32
void main() {
  int gid0 = int(gl_GlobalInvocationID.x);
  int gid = int(gl_GlobalInvocationID.x);
  int N = int(n[0]);
  if (gid < N) {
    int jVal = int(j[0]);
    float xij = X[((jVal * N) + gid)];
    float v = xij;
    int kVal = int(k[0]);
    for (int ii = 0; ii < int(jVal); ++ii) {
      float dot = coeffs[ii];
      float q = X[((ii * N) + gid)];
      v = (v - (dot * q));
    }
    Xj[gid] = v;
  }
}
